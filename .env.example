# ============================================================================
# Root environment — consumed by docker-compose for variable interpolation.
# Laravel has its own backend/.env (generated from backend/.env.example).
# Copy this file to .env and adjust as needed.
# ============================================================================

COMPOSE_PROJECT_NAME=sukify

# Host-exposed ports (change if they clash on your machine)
NGINX_PORT=8088
VITE_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379
CENTRIFUGO_PORT=8000
MEILISEARCH_PORT=7700
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# UID/GID for the php-fpm container's www-data (Linux hosts). Safe defaults.
UID=1000
GID=1000

# --- PostgreSQL ---
POSTGRES_DB=sukify
POSTGRES_USER=sukify
POSTGRES_PASSWORD=secret

# --- MinIO (S3 dev storage) ---
MINIO_ROOT_USER=sukify
MINIO_ROOT_PASSWORD=sukifysecret
MINIO_BUCKET=sukify

# --- Meilisearch ---
MEILI_MASTER_KEY=masterKeyChangeMe

# --- Centrifugo (must match docker/centrifugo/config.json) ---
CENTRIFUGO_HMAC_SECRET=change-me-centrifugo-hmac-secret
CENTRIFUGO_API_KEY=change-me-centrifugo-api-key

# Environment
/.env
/backend/.env
/frontend/.env
/frontend/.env.local

# Dependencies (kept in named Docker volumes, never committed)
/backend/vendor/
/frontend/node_modules/
/backend/node_modules/

# Laravel runtime
/backend/storage/*.key
/backend/storage/framework/cache/data/*
/backend/storage/framework/sessions/*
/backend/storage/framework/views/*
/backend/storage/logs/*
/backend/bootstrap/cache/*.php
/backend/public/build/
/backend/public/hot

# Frontend build
/frontend/dist/
/frontend/.vite/

# Reference material (huge Spotify HTML dumps — not part of the product)
/_reference/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
